# Copy this file to .env and fill in your keys.
# Never commit the real .env file.

# Football data (choose one)
FOOTBALL_DATA_API_KEY=
API_FOOTBALL_KEY=

# Weather
OPENWEATHER_API_KEY=

# Odds
THE_ODDS_API_KEY=

# Claude (for the slide 8 prediction)
ANTHROPIC_API_KEY=

# Meta / Instagram Graph API
META_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=

# TikTok Content Posting API
TIKTOK_ACCESS_TOKEN=

# Telegram approval bot (optional: if set, slides are pushed for approval there
# instead of the terminal o/n prompt).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Mode: "mock" uses the JSON fixture, "live" hits the real APIs
DATA_MODE=mock
